# Database
SNEP_DATABASE_URL=postgresql+asyncpg://snep:snep@postgres:5432/snep

# API
SNEP_API_HOST=0.0.0.0
SNEP_API_PORT=8000
SNEP_SECRET_KEY=change-me-in-production
SNEP_DEBUG=true
SNEP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Networking
SNEP_NETWORK_MODE=auto
SNEP_BIND_ADDRESS=0.0.0.0
SNEP_LOOPBACK_RANGE=127.0.0.0/8
SNEP_SSH_BASE_PORT=10000
SNEP_SNMP_BASE_PORT=20000
SNEP_PREFER_STANDARD_PORTS=true

# SSH Emulation
SNEP_SSH_HOST_KEY_PATH=/app/data/host_key

# Import: NetBox
SNEP_NETBOX_URL=
SNEP_NETBOX_TOKEN=

# Import: Nautobot
SNEP_NAUTOBOT_URL=
SNEP_NAUTOBOT_TOKEN=

# Import: NetGraphy (Neo4j)
SNEP_NETGRAPHY_NEO4J_URI=bolt://localhost:7687
SNEP_NETGRAPHY_NEO4J_USER=neo4j
SNEP_NETGRAPHY_NEO4J_PASSWORD=netgraphy
